<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
    "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">

<module name="Checker">
  <property name="charset" value="UTF-8"/>

  <module name="FileTabCharacter"/>

  <module name="TreeWalker">
    <module name="OuterTypeFilename"/>
    <module name="OneTopLevelClass"/>
    <module name="AvoidStarImport"/>
    <module name="UnusedImports"/>
    <module name="ModifierOrder"/>
    <module name="RedundantModifier"/>
    <module name="NeedBraces"/>
    <module name="IllegalImport">
      <property name="illegalClasses" value="sun.misc.Unsafe"/>
      <property name="illegalPkgs" value="jdk.internal,com.sun"/>
    </module>
    <module name="RegexpSinglelineJava">
      <property name="format" value="\bsun\.misc\.Unsafe\b"/>
      <property name="message" value="Use of sun.misc.Unsafe is forbidden"/>
      <property name="ignoreComments" value="true"/>
    </module>
    <module name="RegexpSinglelineJava">
      <property name="format" value="\bjdk\.internal\.[A-Za-z0-9_$.]+\b"/>
      <property name="message" value="Use of jdk.internal.* is forbidden"/>
      <property name="ignoreComments" value="true"/>
    </module>
    <module name="RegexpSinglelineJava">
      <property name="format" value="\bcom\.sun\.[A-Za-z0-9_$.]+\b"/>
      <property name="message" value="Use of com.sun.* is forbidden"/>
      <property name="ignoreComments" value="true"/>
    </module>
  </module>
</module>
