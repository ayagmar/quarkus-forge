# Auto-detect text files and normalize line endings
* text=auto

# Force Unix line endings for shell scripts
*.sh text eol=lf
mvnw text eol=lf

# Force Windows line endings for batch/cmd scripts
*.cmd text eol=crlf
*.bat text eol=crlf

# Source files
*.java text
*.xml text
*.yml text
*.yaml text
*.json text
*.properties text
*.adoc text
*.md text
*.css text
*.html text
*.hbs text
*.js text

# Binary files
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.jar binary
*.zip binary
*.gz binary
