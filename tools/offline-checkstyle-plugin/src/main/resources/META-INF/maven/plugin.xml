<?xml version="1.0" encoding="UTF-8"?>
<plugin>
  <name>Offline Checkstyle Stub</name>
  <description>Offline no-op replacement for maven-checkstyle-plugin.</description>
  <groupId>org.apache.maven.plugins</groupId>
  <artifactId>maven-checkstyle-plugin</artifactId>
  <version>99.0-offline</version>
  <goalPrefix>checkstyle</goalPrefix>
  <mojos>
    <mojo>
      <goal>check</goal>
      <implementation>org.apache.maven.plugins.checkstyle.CheckstyleMojo</implementation>
      <language>java</language>
      <instantiationStrategy>per-lookup</instantiationStrategy>
      <executionStrategy>once-per-session</executionStrategy>
      <requiresDependencyResolution>none</requiresDependencyResolution>
      <threadSafe>true</threadSafe>
    </mojo>
  </mojos>
</plugin>
